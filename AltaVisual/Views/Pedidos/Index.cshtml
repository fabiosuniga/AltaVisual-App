@model IEnumerable<AltaVisual.Models.Pedido>

@{
    ViewData["Title"] = "Pedidos";
}

<div class="container mt-4">
    <div class="main-card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0 text-uppercase" style="color: var(--preto-ergo);">PEDIDOS</h2>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 text-uppercase fw-bold">
                <i class="bi bi-plus-lg me-1"></i> NOVO PEDIDO
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center align-middle">CÓDIGO</th>
                        <th class="text-center align-middle">CLIENTE</th>
                        <th class="text-center align-middle">DATA DO PEDIDO</th>
                        <th class="text-center align-middle">STATUS</th>
                        <th class="text-center align-middle" style="min-width: 400px;">AÇÕES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-vinho">#@item.Id</td>
                            <td class="text-center">@item.Cliente.Nome</td>
                            <td class="text-center">@item.Data.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                @{
                                    var corBadge = item.Status switch
                                    {
                                        "Em produção" => "status-producao",
                                        "Disponível para retirada" => "status-disponivel-azul",
                                        "Pago" => "status-pago",
                                        "Retirado" => "status-retirado",
                                        _ => "bg-light text-dark"
                                    };
                                }
                                <span class="badge rounded-pill px-3 py-2 text-uppercase @corBadge">@item.Status</span>
                            </td>
                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3 fw-bold text-uppercase">EDITAR</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-azul btn-sm rounded-pill px-3 fw-bold text-uppercase">DETALHES</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-vinho btn-sm rounded-pill px-3 fw-bold text-uppercase">EXCLUIR</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>