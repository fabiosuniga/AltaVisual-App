@model AltaVisual.Models.Pedido

@{
    ViewData["Title"] = "Novo Pedido";
}

<div class="container mt-4">
    <div class="main-card shadow-sm p-4">
        
        <div class="mb-4">
            <h2 class="fw-bold mb-0 text-uppercase" style="color: var(--preto-ergo);">NOVO PEDIDO</h2>
        </div>

        <div class="row">
            <div class="col-md-6">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="ClienteId" class="form-label fw-bold text-uppercase small">Cliente</label>
                        <select asp-for="ClienteId" class="form-select rounded-pill border-1" asp-items="ViewBag.ClienteId"></select>
                    </div>

                    <div class="form-group d-flex gap-3">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 text-uppercase">CRIAR</button>
                        <a asp-action="Index" class="btn btn-dark rounded-pill px-4 text-uppercase">VOLTAR</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}