@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">
    <div class="row g-0 mb-4">
        <div class="col-12">
            <div class="header-status-bar shadow-sm">
                <div class="status-item main-greeting">
                    <i class="fas fa-desktop"></i>
                    <span>Painel de Controle</span>
                </div>

                <div class="status-item">
                    <i class="far fa-calendar-alt"></i>
                    <span>@DateTime.Now.ToString("dd 'de' MMMM, yyyy")</span>
                </div>

                <div class="status-item highlight">
                    <div class="status-dot"></div>
                    <span>Sistema Online</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card card-dashboard h-100 shadow-sm">
                <div class="card-body text-center d-flex flex-column justify-content-between p-4">
                    <div>
                        <i class="bi bi-people-fill fs-1 mb-2 icon-main"></i>
                        <h5 class="card-title text-uppercase small fw-bold">Total de Clientes</h5>
                        <h2 class="display-5 fw-bold">@ViewBag.TotalClientes</h2>
                    </div>
                    <div class="mt-3">
                        <a asp-controller="Clientes" asp-action="Index" class="btn btn-action w-100">Gerenciar</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card card-dashboard h-100 shadow-sm">
                <div class="card-body text-center d-flex flex-column justify-content-between p-4">
                    <div>
                        <i class="bi bi-cart-check-fill fs-1 mb-2 icon-main"></i>
                        <h5 class="card-title text-uppercase small fw-bold">Pedidos Realizados</h5>
                        <h2 class="display-5 fw-bold">@ViewBag.TotalPedidos</h2>
                    </div>
                    <div class="mt-3">
                        <a asp-controller="Pedidos" asp-action="Index" class="btn btn-action w-100">Ver Pedidos</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card card-dashboard h-100 shadow-sm">
                <div class="card-body text-center d-flex flex-column justify-content-between p-4">
                    <div>
                        <i class="bi bi-lightning-charge-fill fs-1 mb-2 icon-main"></i>
                        <h5 class="card-title text-uppercase small fw-bold">Ações Rápidas</h5>
                    </div>
                    <div class="d-grid gap-2">
                        <a asp-controller="Pedidos" asp-action="Create" class="btn btn-action w-100">Novo Pedido</a>
                        <a asp-controller="Clientes" asp-action="Create" class="btn btn-action w-100">Novo Cliente</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>