@model AltaVisual.Models.Adesivo

@{
    ViewData["Title"] = "Excluir Adesivo";
}

<div class="container mt-4">
    <div class="main-card shadow-sm p-4 bg-white rounded-4">
        <div class="mb-4">
            <h2 class="fw-bold mb-0 text-uppercase" style="color: var(--preto-ergo);">EXCLUIR ADESIVO</h2>
            <h5 class="text-danger fw-bold mt-2">Você tem certeza que deseja remover este adesivo?</h5>
        </div>

        <hr class="opacity-10 mb-4" />

        <div class="row mb-5 g-4">
            <div class="col-md-4">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Descrição</label>
                <span class="fs-5 fw-bold">@Html.DisplayFor(model => model.Descricao)</span>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Dimensões</label>
                <span class="fs-5">@Model.LarguraCm x @Model.AlturaCm (CM)</span>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Quantidade</label>
                <span class="fs-5">@Html.DisplayFor(model => model.Quantidade)</span>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Valor Total</label>
                <span class="fs-5 fw-bold text-danger">@Html.DisplayFor(model => model.ValorFinal)</span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-primary rounded-pill px-5 text-uppercase fw-bold">CONFIRMAR EXCLUSÃO</button>
                <a asp-action="Index" class="btn btn-dark rounded-pill px-5 text-uppercase">CANCELAR E VOLTAR</a>
            </div>
        </form>
    </div>
</div>