@model AltaVisual.Models.Adesivo

@{
    ViewData["Title"] = "Detalhes do Adesivo";
}

<div class="container mt-4">
    <div class="main-card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h2 class="fw-bold mb-0 text-uppercase" style="color: var(--preto-ergo);">DETALHES DO ADESIVO</h2>
                <h5 class="text-vinho fw-bold mt-2">Nº #@Model.Id</h5>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-dark rounded-pill px-4 text-uppercase fw-bold">EDITAR</a>
                <a asp-action="Index" class="btn btn-dark rounded-pill px-4 text-uppercase">VOLTAR</a>
            </div>
        </div>

        <hr class="opacity-10 mb-4" />

        <div class="row g-4">
            <div class="col-md-2">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Largura (CM)</label>
                <span class="fs-5 fw-bold">@Html.DisplayFor(model => model.LarguraCm)</span>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Altura (CM)</label>
                <span class="fs-5 fw-bold">@Html.DisplayFor(model => model.AlturaCm)</span>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Quantidade</label>
                <span class="fs-5">@Html.DisplayFor(model => model.Quantidade)</span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Descrição do Item</label>
                <span class="fs-5">@Html.DisplayFor(model => model.Descricao)</span>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Preço por M²</label>
                <span class="fs-5">@Html.DisplayFor(model => model.PrecoBase)</span>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-uppercase small text-muted d-block">Valor Final</label>
                <span class="fs-5 fw-bold text-vinho">@Html.DisplayFor(model => model.ValorFinal)</span>
            </div>
        </div>
    </div>
</div>